<div class="project-storybook-frame">
  <main class="ds-card ds-panel">
    <div class="ds-topbar">
      <div>
        <p class="ds-meta" style="margin: 0 0 8px">Template</p>
        <h1 class="ds-heading">Task inbox</h1>
      </div>
      <button class="ds-button ds-button-primary" type="button">New task</button>
    </div>
    <div class="ds-layout ds-layout-two-column">
      <section class="ds-panel" style="padding: 0">
        <div class="ds-card ds-panel" style="background: var(--project-panel); margin-bottom: 16px">
          <p class="ds-meta" style="margin: 0">Filter bar slot</p>
        </div>
        <div class="ds-card ds-panel" style="background: #ffffff">
          <p class="ds-meta" style="margin: 0">Task list slot</p>
        </div>
      </section>
      <aside class="ds-card ds-panel" style="background: var(--project-panel)">
        <p class="ds-meta" style="margin: 0">Details panel slot</p>
      </aside>
    </div>
  </main>
</div>
