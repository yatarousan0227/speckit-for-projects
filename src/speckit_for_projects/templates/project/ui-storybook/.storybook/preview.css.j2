:root {
  color-scheme: light;
  --project-bg: #f3f2ec;
  --project-surface: #fffdf7;
  --project-panel: #f7f4eb;
  --project-text: #1c2430;
  --project-muted: #667180;
  --project-border: #d8d0bc;
  --project-accent: #0f766e;
  --project-accent-soft: #d9f3ef;
  --project-success: #1d7a46;
  --project-warning: #9a6700;
  --project-danger: #b42318;
  --project-shadow: 0 18px 40px rgba(28, 36, 48, 0.08);
  --project-radius: 16px;
  --project-font: "Helvetica Neue", Helvetica, Arial, sans-serif;
}

html,
body,
#storybook-root {
  min-height: 100%;
}

body {
  margin: 0;
  background:
    radial-gradient(circle at top left, #fffaf0 0, transparent 32%),
    linear-gradient(180deg, #fcfbf7 0%, var(--project-bg) 100%);
  color: var(--project-text);
  font-family: var(--project-font);
}

.project-storybook-frame {
  padding: 24px;
}

.ds-card {
  background: var(--project-surface);
  border: 1px solid var(--project-border);
  border-radius: var(--project-radius);
  box-shadow: var(--project-shadow);
}

.ds-button {
  border: 1px solid transparent;
  border-radius: 999px;
  padding: 10px 16px;
  font: inherit;
  font-weight: 600;
}

.ds-button-primary {
  background: var(--project-accent);
  color: #ffffff;
}

.ds-button-secondary {
  background: #ffffff;
  border-color: var(--project-border);
  color: var(--project-text);
}

.ds-badge {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 4px 10px;
  font-size: 12px;
  font-weight: 700;
}

.ds-badge-success {
  background: #e7f6ed;
  color: var(--project-success);
}

.ds-badge-warning {
  background: #fff1cc;
  color: var(--project-warning);
}

.ds-input-block {
  display: grid;
  gap: 6px;
}

.ds-label {
  font-size: 14px;
  font-weight: 700;
}

.ds-help {
  color: var(--project-muted);
  font-size: 13px;
}

.ds-input {
  width: 100%;
  box-sizing: border-box;
  border: 1px solid var(--project-border);
  border-radius: 12px;
  padding: 12px 14px;
  font: inherit;
  background: #ffffff;
}

.ds-layout {
  display: grid;
  gap: 20px;
}

.ds-layout-two-column {
  grid-template-columns: minmax(0, 2fr) minmax(280px, 1fr);
}

.ds-panel {
  padding: 20px;
}

.ds-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  gap: 12px;
}

.ds-list-item {
  display: grid;
  gap: 8px;
  padding: 16px 18px;
  border: 1px solid var(--project-border);
  border-radius: 14px;
  background: #ffffff;
}

.ds-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.ds-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 20px;
}

.ds-heading {
  margin: 0;
  font-size: 28px;
  line-height: 1.1;
}

.ds-subheading {
  margin: 0;
  font-size: 18px;
  line-height: 1.3;
}

.ds-meta {
  color: var(--project-muted);
  font-size: 13px;
}

@media (max-width: 900px) {
  .ds-layout-two-column {
    grid-template-columns: 1fr;
  }
}
